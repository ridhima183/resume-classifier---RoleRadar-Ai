SECRET_KEY=change-me
# SQLite (default): sqlite:///path/to/resume_classifier.db
# PostgreSQL: postgresql+psycopg2://user:password@host:port/dbname
DATABASE_URL=postgresql+psycopg2://resume_user:resume_password@localhost:5432/resume_classifier
ACCESS_TOKEN_EXPIRES_MINUTES=60
RESET_TOKEN_EXPIRES_MINUTES=30
FRONTEND_URL=http://localhost:3000
API_BASE_URL=http://127.0.0.1:8000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:5173
# Comma-separated admin emails (for /admin/* endpoints)
ADMIN_EMAILS=admin@example.com

# SMTP Configuration for password reset emails
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

# OAuth Configuration (Optional - for social login)
# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/api/auth/google/callback

# LinkedIn OAuth
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://127.0.0.1:8000/api/auth/linkedin/callback

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://127.0.0.1:8000/api/auth/github/callback

# Password Requirements
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL=true
